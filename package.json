{
  "name": "canvas-input-manager",
  "version": "0.4.0",
  "description": "A simple canvas input manager",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "types": "lib/esm/index.d.ts",
  "repository": "https://github.com/kputnins/canvas-input-manager.git",
  "author": "Kasars Putniņš",
  "license": "MIT",
  "scripts": {
    "transpile-esm": "tsc -p ./tsconfig-esm.json",
    "transpile-cjs": "tsc -p ./tsconfig-cjs.json",
    "lint": "eslint --fix \"./src/**/*.{js,jsx,ts,tsx,json}\"",
    "lint-types": "tsc --noEmit",
    "format": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "update": "yarn upgrade-interactive",
    "audit-npm": "yarn npm audit"
  },
  "packageManager": "yarn@3.1.1",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "eslint": "^8.3.0",
    "eslint-config-airbnb-typescript": "^16.0.0",
    "eslint-config-claims-intake": "^3.2.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jest": "^25.3.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.27.1",
    "eslint-plugin-react-hooks": "^4.3.0",
    "eslint-plugin-testing-library": "^5.0.0",
    "prettier": "^2.5.0",
    "typescript": "4.4.4"
  }
}
